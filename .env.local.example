# Copia este archivo como .env.local y rellena los valores.

# Anthropic Claude (motor primario de análisis capilar)
# Consíguelo en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o (fallback automático si Claude falla)
# Consíguelo en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Supabase (auth + base de datos + storage)
# Project Settings → API en https://app.supabase.com/
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Upstash Redis (rate limiting de las APIs de IA)
# Crear DB en https://console.upstash.com/redis (free tier alcanza)
# Si quedan vacías, el rate limit se deshabilita y se loguea un warning.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase service_role (mutaciones de pagos/suscripciones, SOLO server)
# Project Settings -> API -> service_role. NUNCA exponer con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Bold (pasarela de pagos Colombia) - ver PAGOS.md
# Llaves en bold.co -> Integraciones -> API (par de prueba y de produccion)
BOLD_API_KEY=
BOLD_SECRET_KEY=
# true mientras uses llaves de prueba (el checkout sale en modo sandbox)
BOLD_SANDBOX=true
# Proveedor de pagos activo (default: bold)
PAYMENT_PROVIDER=bold
